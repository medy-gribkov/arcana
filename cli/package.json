{
  "name": "@sporesec/arcana",
  "version": "4.0.0",
  "description": "Context intelligence for AI coding agents. 74 skills, budget-aware curation, output compression, cross-session memory, MCP management. 7 platforms.",
  "bin": {
    "arcana": "dist/index.js"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:types": "tsc --emitDeclarationOnly",
    "build:check": "tsc --noEmit",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent-skills",
    "claude",
    "claude-code",
    "cursor",
    "codex",
    "gemini",
    "windsurf",
    "aider",
    "antigravity",
    "ai",
    "ai-agents",
    "skills",
    "cli",
    "context-management",
    "token-optimization",
    "mcp",
    "developer-tools",
    "automation",
    "typescript",
    "golang",
    "python",
    "react",
    "nextjs",
    "devops",
    "security",
    "testing",
    "compression",
    "curation"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "Medy Gribkov",
    "email": "medy@sporesec.com",
    "url": "https://sporesec.com"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/medy-gribkov"
    },
    {
      "type": "individual",
      "url": "https://buymeacoffee.com/medygribkov"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medy-gribkov/arcana.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/medy-gribkov/arcana",
  "bugs": {
    "url": "https://github.com/medy-gribkov/arcana/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "ora": "^9.3.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
